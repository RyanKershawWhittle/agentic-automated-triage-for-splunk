# =============================================================================
# Alert-Triage Pipeline configuration
# Copy to `.env` and fill in the SUBSTITUTE values for your environment.
# `.env` is gitignored — never commit real tokens/keys.
#
# IMPORTANT: docker-compose reads this via `env_file`, which does NOT strip
# inline comments after a value. Keep every comment on its OWN line — never
# put `KEY=value   # comment` (the comment becomes part of the value).
# =============================================================================

# ── Splunk (REST + HEC) ──────────────────────────────────────────────────────
# Host as seen FROM the triage processes:
#   - python processes run directly on the host  -> 127.0.0.1
#   - inside docker-compose (the default here)    -> host.docker.internal
SPLUNK_HOST=host.docker.internal
# REST API port (searches)
SPLUNK_MGMT_PORT=8089
# HTTP Event Collector port (populate test data)
SPLUNK_HEC_PORT=8088

# Auth = Bearer tokens ONLY (house rule: no admin:password / Basic at runtime).
# Both tokens are MINTED FOR YOU by scripts/setup_splunk.py and written back here.
# SUBSTITUTE: filled by setup_splunk.py (Splunk JWT, used for REST search)
SPLUNK_API_TOKEN=
# SUBSTITUTE: filled by setup_splunk.py (HEC token, used for data injection)
SPLUNK_HEC_TOKEN=

# Bootstrap creds — used ONCE by setup_splunk.py to /services/auth/login and mint
# the tokens above (form-login session key, not a Basic header). Local dev only.
SPLUNK_USER=admin
# SUBSTITUTE if your splunk-dev admin password differs
SPLUNK_PASSWORD=changeme-dev-1

# TLS verification for Splunk. Local splunk-dev uses a self-signed cert, so this is
# false by default. In PRODUCTION set true (or a path to a CA bundle) to prevent MITM.
SPLUNK_VERIFY_SSL=false

# Splunk Web base used to build clickable deep links in the email (host browser POV).
SPLUNK_WEB_BASE=http://localhost:8000
# local Docker = en-US; Splunk Cloud = en-GB
SPLUNK_WEB_LOCALE=en-US

# Index / sourcetype this pipeline operates on.
TRIAGE_INDEX=triage_demo
TRIAGE_SOURCETYPE=alert_triage:app

# ── SMTP (mailpit test server) ───────────────────────────────────────────────
# 127.0.0.1 if running processes on the host; host.docker.internal inside compose.
SMTP_HOST=host.docker.internal
SMTP_PORT=1025
SMTP_FROM=alert-triage@local.test
SMTP_TO=soc-oncall@local.test
# mailpit web UI + REST API, for verifying delivery
MAILPIT_API=http://localhost:8025

# ── Anthropic (orchestrator brain) ───────────────────────────────────────────
# SUBSTITUTE: your Claude API key (sk-ant-...). REQUIRED for the live model call.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# ── Service ports ────────────────────────────────────────────────────────────
# FastAPI webhook listener
WEBHOOK_PORT=5001
# MCP server (SSE/HTTP transport)
MCP_PORT=8050
# sse | stdio
MCP_TRANSPORT=sse
